# AI Providers (at least one required)
GROQ_API_KEY=gsk_your_groq_api_key
HF_TOKEN=hf_your_huggingface_token
OPENAI_API_KEY=sk-your_openai_api_key

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_EXPIRES_IN=24h

# Max upload file size in MB (default: 25)
MAX_FILE_SIZE_MB=25

# LLM model for Groq (default: google/gemma-4-31B-it)
LLM_MODEL=google/gemma-4-31B-it

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/csv_ext

# Redis (caching & rate limiting)
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage for CSV uploads)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=csv-uploads
MINIO_REGION=us-east-1

# Batch processing
BATCH_SIZE=500
